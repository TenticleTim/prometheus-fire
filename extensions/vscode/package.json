{
  "name": "thesmos-governance-vscode",
  "displayName": "Thesmos Governance",
  "description": "Real-time AI repo governance — inline findings, health scores, and adapter sync for Claude, Gemini, Cursor, Copilot, and Codex.",
  "version": "1.7.1",
  "publisher": "holleystudio",
  "author": {
    "name": "Matthew Holley",
    "email": "holley42@yahoo.com",
    "url": "https://holley.studio"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Holley-Studio/thesmos-governance.git",
    "directory": "extensions/vscode"
  },
  "engines": {
    "vscode": "^1.100.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "icon": "resources/thesmos-marketplace.png",
  "galleryBanner": {
    "color": "#050408",
    "theme": "dark"
  },
  "badges": [
    {
      "url": "https://img.shields.io/github/actions/workflow/status/Holley-Studio/thesmos-governance/ci.yml?branch=main",
      "href": "https://github.com/Holley-Studio/thesmos-governance/actions",
      "description": "CI"
    },
    {
      "url": "https://img.shields.io/npm/v/thesmos-governance",
      "href": "https://www.npmjs.com/package/thesmos-governance",
      "description": "npm version"
    }
  ],
  "qna": "https://github.com/Holley-Studio/thesmos-governance/discussions",
  "homepage": "https://holley.studio/thesmos",
  "bugs": {
    "url": "https://github.com/Holley-Studio/thesmos-governance/issues"
  },
  "sponsor": {
    "url": "https://github.com/sponsors/Holley-Studio"
  },
  "keywords": [
    "thesmos",
    "governance",
    "ai-governance",
    "ai-coding",
    "mcp",
    "AI",
    "Claude",
    "Cursor",
    "linter",
    "code review",
    "security",
    "Gemini",
    "Copilot"
  ],
  "activationEvents": [
    "workspaceContains:.thesmos/config.json",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "thesmos.scan",
        "title": "Scan Repository",
        "category": "Thesmos",
        "icon": "$(search)"
      },
      {
        "command": "thesmos.reviewFile",
        "title": "Review Current File",
        "category": "Thesmos",
        "icon": "$(eye)"
      },
      {
        "command": "thesmos.health",
        "title": "Show Health Score",
        "category": "Thesmos",
        "icon": "$(pulse)"
      },
      {
        "command": "thesmos.adapters",
        "title": "Regenerate AI Adapters",
        "category": "Thesmos",
        "icon": "$(sync)"
      },
      {
        "command": "thesmos.openConfig",
        "title": "Open Config",
        "category": "Thesmos",
        "icon": "$(settings-gear)"
      },
      {
        "command": "thesmos.refreshFindings",
        "title": "Refresh Findings",
        "category": "Thesmos",
        "icon": "$(refresh)"
      },
      {
        "command": "thesmos.autopilot.generate",
        "title": "Generate Autopilot Plan",
        "category": "Thesmos Autopilot",
        "icon": "$(wand)"
      },
      {
        "command": "thesmos.autopilot.cancel",
        "title": "Cancel Running Session",
        "category": "Thesmos Autopilot",
        "icon": "$(stop-circle)"
      },
      {
        "command": "thesmos.autopilot.review",
        "title": "Review Session Diff (AI)",
        "category": "Thesmos Autopilot",
        "icon": "$(eye)"
      },
      {
        "command": "thesmos.autopilot.openPR",
        "title": "Open Draft PR",
        "category": "Thesmos Autopilot",
        "icon": "$(git-pull-request)"
      },
      {
        "command": "thesmos.autopilot.viewJournal",
        "title": "View Session Journal",
        "category": "Thesmos Autopilot",
        "icon": "$(notebook)"
      },
      {
        "command": "thesmos.autopilot.revert",
        "title": "Revert Session (Delete Branch)",
        "category": "Thesmos Autopilot",
        "icon": "$(discard)"
      },
      {
        "command": "thesmos.importScan",
        "title": "Scan Imports (Supply Chain Check)",
        "category": "Thesmos",
        "icon": "$(package)"
      },
      {
        "command": "thesmos.debtScan",
        "title": "Scan AI Debt",
        "category": "Thesmos",
        "icon": "$(graph)"
      },
      {
        "command": "thesmos.contextSnapshot",
        "title": "Snapshot Project Context",
        "category": "Thesmos",
        "icon": "$(bookmark)"
      },
      {
        "command": "thesmos.contextHealth",
        "title": "Show Context Health",
        "category": "Thesmos",
        "icon": "$(history)"
      },
      {
        "command": "thesmos.scopeInit",
        "title": "Initialize Agent Scope",
        "category": "Thesmos",
        "icon": "$(shield)"
      },
      {
        "command": "thesmos.scopeStatus",
        "title": "Show Agent Scope",
        "category": "Thesmos",
        "icon": "$(lock)"
      },
      {
        "command": "thesmos.scopeCheck",
        "title": "Check Path or Command Against Scope",
        "category": "Thesmos",
        "icon": "$(question)"
      },
      {
        "command": "thesmos.tokensReport",
        "title": "Show Token Usage Report",
        "category": "Thesmos",
        "icon": "$(symbol-number)"
      },
      {
        "command": "thesmos.tokensReset",
        "title": "Reset Session Token Budget",
        "category": "Thesmos",
        "icon": "$(debug-restart)"
      },
      {
        "command": "thesmos.tokensBudget",
        "title": "Show Token Budget Config",
        "category": "Thesmos",
        "icon": "$(credit-card)"
      },
      {
        "command": "thesmos.commitLint",
        "title": "Lint Last Commit Message",
        "category": "Thesmos",
        "icon": "$(git-commit)"
      },
      {
        "command": "thesmos.commitCreate",
        "title": "Create Commit (Guided Wizard)",
        "category": "Thesmos",
        "icon": "$(add)"
      },
      {
        "command": "thesmos.vercelLint",
        "title": "Lint Vercel Deployment Config",
        "category": "Thesmos",
        "icon": "$(cloud)"
      },
      {
        "command": "thesmos.agents.invoke",
        "title": "Invoke Agent",
        "category": "Thesmos Agents",
        "icon": "$(play)"
      },
      {
        "command": "thesmos.tokens.report",
        "title": "Show Token Usage",
        "category": "Thesmos",
        "icon": "$(circuit-board)"
      },
      {
        "command": "thesmos.fix.single",
        "title": "Fix This Issue",
        "category": "Thesmos",
        "icon": "$(zap)"
      },
      {
        "command": "thesmos.fix.all",
        "title": "Fix All Auto-Fixable",
        "category": "Thesmos",
        "icon": "$(zap)"
      },
      {
        "command": "thesmos.fix.copyPrompt",
        "title": "Copy AI Fix Prompt",
        "category": "Thesmos",
        "icon": "$(clippy)"
      },
      {
        "command": "thesmos.fixWithAi",
        "title": "Fix with AI",
        "category": "Thesmos",
        "icon": "$(sparkle)"
      },
      {
        "command": "thesmos.pantheon.routingMode",
        "title": "Pantheon Routing Mode",
        "category": "Thesmos Agents",
        "icon": "$(zap)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "thesmos",
          "title": "Thesmos Governance",
          "icon": "resources/thesmos-activitybar.svg"
        }
      ]
    },
    "views": {
      "thesmos": [
        {
          "id": "thesmos.findingsView",
          "name": "Findings",
          "icon": "$(shield)"
        },
        {
          "id": "thesmos.autopilotView",
          "name": "Autopilot",
          "icon": "$(rocket)"
        },
        {
          "id": "thesmos.agentsView",
          "name": "Agents",
          "icon": "$(person-add)"
        },
        {
          "id": "thesmos.agentActivity",
          "name": "Agent Activity",
          "icon": "$(comment-discussion)"
        }
      ]
    },
    "viewsWelcome": [
      {
        "view": "thesmos.findingsView",
        "contents": "No Thesmos report found.\n[Run Thesmos Scan](command:thesmos.scan)\n\nLearn more at [holley.studio/thesmos](https://holley.studio/thesmos)",
        "when": "!thesmos.active"
      },
      {
        "view": "thesmos.agentActivity",
        "contents": "No agent activity yet — god dispatches appear here live.\n\nSummon the full Pantheon: 66 specialist agents orchestrated by Zeus.\n[Get the Full Pantheon](https://holley.studio/thesmos)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "thesmos.fixWithAi",
          "when": "view == thesmos.findingsView",
          "group": "navigation"
        },
        {
          "command": "thesmos.fix.all",
          "when": "view == thesmos.findingsView",
          "group": "navigation"
        },
        {
          "command": "thesmos.refreshFindings",
          "when": "view == thesmos.findingsView",
          "group": "navigation"
        },
        {
          "command": "thesmos.health",
          "when": "view == thesmos.findingsView",
          "group": "navigation"
        },
        {
          "command": "thesmos.debtScan",
          "when": "view == thesmos.findingsView",
          "group": "navigation"
        },
        {
          "command": "thesmos.importScan",
          "when": "view == thesmos.findingsView",
          "group": "navigation"
        },
        {
          "command": "thesmos.autopilot.generate",
          "when": "view == thesmos.autopilotView",
          "group": "navigation"
        },
        {
          "command": "thesmos.autopilot.cancel",
          "when": "view == thesmos.autopilotView && thesmos.autopilotActive",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "thesmos.fix.single",
          "when": "view == thesmos.findingsView && viewItem == fixableFinding",
          "group": "fix@1"
        },
        {
          "command": "thesmos.fix.copyPrompt",
          "when": "view == thesmos.findingsView && viewItem == fixableFinding",
          "group": "fix@2"
        },
        {
          "command": "thesmos.fix.copyPrompt",
          "when": "view == thesmos.findingsView && viewItem == finding",
          "group": "fix@1"
        },
        {
          "command": "thesmos.autopilot.cancel",
          "when": "view == thesmos.autopilotView && viewItem == autopilotHeader",
          "group": "autopilot@1"
        },
        {
          "command": "thesmos.autopilot.viewJournal",
          "when": "view == thesmos.autopilotView && viewItem == autopilotHeader",
          "group": "autopilot@2"
        },
        {
          "command": "thesmos.autopilot.review",
          "when": "view == thesmos.autopilotView && viewItem == autopilotHeader",
          "group": "autopilot@3"
        },
        {
          "command": "thesmos.autopilot.openPR",
          "when": "view == thesmos.autopilotView && viewItem == autopilotHeader",
          "group": "autopilot@4"
        },
        {
          "command": "thesmos.autopilot.revert",
          "when": "view == thesmos.autopilotView && viewItem == autopilotHeader",
          "group": "autopilot@5"
        }
      ],
      "commandPalette": [
        {
          "command": "thesmos.reviewFile",
          "when": "editorIsOpen"
        },
        {
          "command": "thesmos.fixWithAi",
          "when": "thesmos.active"
        },
        {
          "command": "thesmos.fix.all",
          "when": "thesmos.active"
        },
        {
          "command": "thesmos.fix.single",
          "when": "false"
        },
        {
          "command": "thesmos.fix.copyPrompt",
          "when": "false"
        },
        {
          "command": "thesmos.autopilot.cancel",
          "when": "thesmos.autopilotActive"
        },
        {
          "command": "thesmos.autopilot.review",
          "when": "thesmos.autopilotActive"
        },
        {
          "command": "thesmos.autopilot.openPR",
          "when": "thesmos.autopilotActive"
        },
        {
          "command": "thesmos.autopilot.revert",
          "when": "thesmos.autopilotActive"
        }
      ]
    },
    "configuration": {
      "title": "Thesmos Governance",
      "properties": {
        "thesmos.enable": {
          "type": "boolean",
          "default": true,
          "description": "Enable Thesmos Governance."
        },
        "thesmos.runOnSave": {
          "type": "boolean",
          "default": true,
          "description": "Re-run review on every file save."
        },
        "thesmos.debounceMs": {
          "type": "number",
          "default": 1000,
          "minimum": 200,
          "maximum": 10000,
          "description": "Milliseconds to debounce before re-analysing after a file save."
        },
        "thesmos.showStatusBar": {
          "type": "boolean",
          "default": true,
          "description": "Show governance health in the status bar."
        },
        "thesmos.binaryPath": {
          "type": "string",
          "default": "",
          "description": "Absolute path to the thesmos binary. Leave empty to auto-detect from node_modules/.bin or PATH."
        },
        "thesmos.autoScan": {
          "type": "boolean",
          "default": false,
          "description": "Automatically run 'thesmos scan' on activation when .thesmos/report.json is missing."
        },
        "thesmos.autopilot.baseBranch": {
          "type": "string",
          "default": "main",
          "description": "Base branch to diff against when reviewing an autopilot session."
        },
        "thesmos.codeLens.enable": {
          "type": "boolean",
          "default": true,
          "description": "Show CodeLens annotations above BLOCKER and HIGH findings."
        },
        "thesmos.inlineDiagnostics.enable": {
          "type": "boolean",
          "default": true,
          "description": "Show Error Lens-style inline text (← [BLOCKER] ...) next to findings."
        },
        "thesmos.minSeverity": {
          "type": "string",
          "enum": [
            "ALL",
            "MEDIUM",
            "HIGH",
            "BLOCKER"
          ],
          "enumDescriptions": [
            "Show all findings",
            "Show MEDIUM and above",
            "Show HIGH and above",
            "Show BLOCKER only"
          ],
          "default": "ALL",
          "description": "Minimum severity to display in the Findings tree."
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "typecheck": "tsc --noEmit",
    "package": "vsce package --no-dependencies",
    "publish:vsce": "vsce publish --no-dependencies",
    "publish:ovsx": "ovsx publish --no-dependencies",
    "test": "vitest run"
  },
  "dependencies": {
    "vscode-languageclient": "^10.0.1"
  },
  "devDependencies": {
    "@types/node": "^26.1.0",
    "@types/vscode": "^1.100.0",
    "@vscode/vsce": "^3.9.2",
    "ovsx": "^1.0.2",
    "esbuild": "^0.28.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
