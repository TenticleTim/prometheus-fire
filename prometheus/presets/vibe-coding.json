{
  "$schema": "../config.schema.json",
  "name": "prometheus/vibe-coding",
  "version": "1.0.0",
  "description": "Purpose-built preset for vibe-coded and AI-assisted projects. Enforces the 25 security controls that research shows AI tools consistently skip. The OWASP Top 10 for AI-generated code.",
  "failOnSeverity": ["BLOCKER"],
  "warnOnSeverity": ["HIGH"],
  "largeFileThreshold": 400,
  "reportMaxAgeDays": 14,
  "disabledRules": [
    "monday_write_no_gate",
    "design_system_bypass",
    "duplicate_component_pattern"
  ],
  "severityRules": [
    { "category": "vibe_csrf_missing",             "severity": "BLOCKER" },
    { "category": "vibe_ssrf",                     "severity": "BLOCKER" },
    { "category": "vibe_no_rate_limit",            "severity": "HIGH"    },
    { "category": "vibe_missing_security_headers", "severity": "HIGH"    },
    { "category": "vibe_cors_wildcard",            "severity": "BLOCKER" },
    { "category": "vibe_missing_input_validation", "severity": "HIGH"    },
    { "category": "vibe_hardcoded_secret",         "severity": "BLOCKER" },
    { "category": "vibe_eval_usage",               "severity": "BLOCKER" },
    { "category": "vibe_sql_template_injection",   "severity": "BLOCKER" },
    { "category": "vibe_path_traversal",           "severity": "BLOCKER" },
    { "category": "vibe_unvalidated_redirect",     "severity": "HIGH"    },
    { "category": "vibe_insecure_cookie",          "severity": "HIGH"    },
    { "category": "vibe_weak_random",              "severity": "HIGH"    },
    { "category": "vibe_error_stack_leak",         "severity": "MEDIUM"  },
    { "category": "vibe_no_request_timeout",       "severity": "MEDIUM"  },
    { "category": "vibe_prototype_pollution",      "severity": "HIGH"    },
    { "category": "vibe_xss_inner_html",           "severity": "BLOCKER" },
    { "category": "vibe_missing_auth_middleware",  "severity": "HIGH"    },
    { "category": "vibe_timing_attack",            "severity": "HIGH"    },
    { "category": "vibe_missing_output_encoding",  "severity": "BLOCKER" },
    { "category": "vibe_ai_endpoint_no_auth",      "severity": "BLOCKER" },
    { "category": "vibe_prompt_injection_risk",    "severity": "BLOCKER" },
    { "category": "vibe_missing_zod_on_env",       "severity": "MEDIUM"  },
    { "category": "vibe_insecure_direct_object",   "severity": "BLOCKER" },
    { "category": "vibe_llm_response_unvalidated", "severity": "HIGH"    },
    { "category": "slop_phantom_import",           "severity": "BLOCKER" },
    { "category": "slop_undeclared_import",        "severity": "HIGH"    },
    { "category": "slop_suspicious_package_name",  "severity": "MEDIUM"  },
    { "category": "slop_known_phantom_list",       "severity": "BLOCKER" },
    { "category": "slop_ai_comment_import",        "severity": "MEDIUM"  }
  ]
}
